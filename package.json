{
  "name": "qa-portfolio-lab",
  "version": "1.0.0",
  "description": "Kudos app — a vehicle for demonstrating Playwright API and E2E test automation",
  "main": "src/api/server.ts",
  "scripts": {
    "dev": "concurrently \"npm run dev:service\" \"npm run dev:client\"",
    "dev:service": "TS_NODE_PROJECT=tsconfig.server.json nodemon --watch src/api --exec \"node -r ts-node/register\" src/api/server.ts",
    "dev:client": "vite",
    "start:service": "TS_NODE_PROJECT=tsconfig.server.json node -r ts-node/register src/api/server.ts",
    "db:migrate": "prisma migrate dev",
    "db:deploy": "prisma migrate deploy",
    "db:seed": "prisma db seed",
    "test": "playwright test",
    "test:api": "playwright test --project=api",
    "test:e2e": "playwright test --project=chromium"
  },
  "prisma": {
    "seed": "node -r esbuild-runner/register prisma/seed.ts"
  },
  "dependencies": {
    "@prisma/client": "^5.10.0",
    "bcrypt": "^5.1.1",
    "class-transformer": "^0.5.1",
    "class-validator": "^0.14.1",
    "cors": "^2.8.5",
    "dotenv": "^17.3.1",
    "express": "^4.18.3",
    "jsonwebtoken": "^9.0.2",
    "reflect-metadata": "^0.2.1",
    "routing-controllers": "^0.10.4",
    "sanitize-html": "^2.12.1",
    "typedi": "^0.10.0"
  },
  "devDependencies": {
    "@types/bcrypt": "^5.0.2",
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/jsonwebtoken": "^9.0.6",
    "@types/node": "^20.11.20",
    "@types/react": "^18.2.61",
    "@types/react-dom": "^18.2.19",
    "@types/sanitize-html": "^2.11.0",
    "@vitejs/plugin-react": "^4.2.1",
    "autoprefixer": "^10.4.18",
    "axios": "^1.6.7",
    "concurrently": "^8.2.2",
    "esbuild-runner": "^2.2.2",
    "nodemon": "^3.1.0",
    "postcss": "^8.4.35",
    "prisma": "^5.10.0",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "react-router-dom": "^6.22.2",
    "tailwindcss": "^3.4.1",
    "ts-node": "^10.9.2",
    "typescript": "^5.3.3",
    "vite": "^5.1.4",
    "zustand": "^4.5.2"
  }
}
